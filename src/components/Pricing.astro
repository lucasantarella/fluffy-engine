---
import { platformTiers, creditPlans } from '../data/pricing';
---

<section id="pricing" class="py-24 sm:py-32">
  <div class="section-container">
    <!-- Section heading -->
    <div class="fade-in-section mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">Pricing</p>
      <h2 class="mt-3 font-serif text-4xl text-slate-900 sm:text-5xl">
        Simple, transparent <span class="italic text-brand-600">pricing</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Start free. Scale as your team grows.
      </p>
    </div>

    <!-- Platform Plans -->
    <div class="mt-16 grid gap-8 lg:grid-cols-3">
      {
        platformTiers.map((tier) => (
          <div
            class={`fade-in-section relative rounded-2xl border p-8 transition-all duration-300 ${
              tier.highlighted
                ? 'border-brand-300 bg-white shadow-xl shadow-brand-100/50 ring-1 ring-brand-200'
                : 'border-slate-200 bg-white hover:shadow-lg'
            }`}
          >
            {tier.badge && (
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
                <span class="inline-flex rounded-full bg-gradient-to-r from-brand-600 to-pink-500 px-4 py-1 text-xs font-semibold text-white">
                  {tier.badge}
                </span>
              </div>
            )}

            <h3 class="text-lg font-semibold text-slate-900">{tier.name}</h3>
            <p class="mt-1 text-sm text-slate-500">{tier.description}</p>

            <div class="mt-6 flex items-baseline">
              <span class="font-serif text-5xl text-slate-900">{tier.price}</span>
              {tier.period && <span class="ml-1.5 text-sm text-slate-500">{tier.period}</span>}
            </div>

            <a
              href="#"
              class={`mt-8 block w-full rounded-full py-3 text-center text-sm font-semibold transition-all duration-300 ${
                tier.ctaStyle === 'primary'
                  ? 'btn-primary'
                  : 'border-2 border-slate-200 text-slate-700 hover:border-brand-300 hover:text-brand-600'
              }`}
            >
              {tier.cta}
            </a>

            <ul class="mt-8 space-y-3">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm">
                  {feature.included ? (
                    <svg
                      class="mt-0.5 h-4 w-4 shrink-0 text-brand-500"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  ) : (
                    <svg
                      class="mt-0.5 h-4 w-4 shrink-0 text-slate-300"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" />
                    </svg>
                  )}
                  <span class={feature.included ? 'text-slate-700' : 'text-slate-400'}>
                    {feature.text}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- AI Credits Section -->
    <div class="fade-in-section mt-20">
      <div class="mx-auto max-w-3xl text-center">
        <h3 class="font-serif text-2xl text-slate-900 sm:text-3xl">AI Review Credits</h3>
        <p class="mt-3 text-slate-600">
          Reviews are powered by AI and billed separately from seats. Choose managed AI or bring
          your own key.
        </p>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          creditPlans.map((plan) => (
            <div class="rounded-xl border border-slate-200 bg-white p-6 text-center transition-all hover:shadow-md">
              <h4 class="font-semibold text-slate-900">{plan.name}</h4>
              <div class="mt-2 font-serif text-2xl text-slate-900">{plan.price}</div>
              <p class="mt-1 text-sm text-slate-500">{plan.reviews} reviews/mo</p>
            </div>
          ))
        }
      </div>

      <!-- BYOL callout -->
      <div class="mx-auto mt-8 max-w-2xl rounded-2xl border border-brand-200 bg-brand-50/50 p-6 text-center">
        <h4 class="font-semibold text-slate-900">Bring Your Own Key</h4>
        <p class="mt-2 text-sm leading-relaxed text-slate-600">
          Supply your own Anthropic, OpenAI, Azure OpenAI, or AWS Bedrock API key. AI costs go
          directly to your provider account. <strong>$0 AI cost from us</strong> — you only pay for
          platform seats.
        </p>
      </div>
    </div>
  </div>
</section>

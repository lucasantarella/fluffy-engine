---
const steps = [
  {
    num: '01',
    title: 'Connect',
    description:
      'Install the Forge app from the Atlassian Marketplace. One click, no server setup. Proompt connects to your Jira instance instantly.',
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.54a4.5 4.5 0 00-6.364-6.364L4.5 8.257" /></svg>`,
  },
  {
    num: '02',
    title: 'Configure',
    description:
      'Choose your quality standards. Start with our proven baseline or import your own from Confluence. Adjust scoring dimensions and weights to match what your team cares about.',
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  },
  {
    num: '03',
    title: 'Review',
    description:
      'Click "Review with AI" on any Epic or Story. In 10–15 seconds, get a scorecard with dimension-level scores, specific findings, and a rewritten draft that meets your standards.',
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>`,
  },
  {
    num: '04',
    title: 'Automate',
    description:
      'Set up auto-review rules. When a story moves to "Ready for Dev," Proompt reviews it automatically and posts the scorecard as a Jira comment. No manual trigger needed.',
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  },
  {
    num: '05',
    title: 'Improve',
    description:
      'Track your team\'s story quality over time. See which scoring dimensions improve, which teams write the sharpest stories, and where your process still has gaps.',
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" /></svg>`,
  },
];
---

<section id="how-it-works" class="py-24 sm:py-32">
  <div class="section-container">
    <!-- Section heading -->
    <div class="fade-in-section mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">How it works</p>
      <h2 class="mt-3 font-serif text-4xl text-slate-900 sm:text-5xl">
        From backlog to sprint-ready<br class="hidden sm:block" />
        <span class="italic text-brand-600">in five steps</span>
      </h2>
    </div>

    <!-- Steps -->
    <div class="mt-20 space-y-20 lg:space-y-28">
      {
        steps.map((step, i) => (
          <div
            class={`fade-in-section flex flex-col items-center gap-12 lg:flex-row lg:gap-20 ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}
          >
            {/* Text side */}
            <div class="flex-1">
              <div class="flex items-center gap-4">
                <span class="font-serif text-5xl font-light text-brand-200">{step.num}</span>
                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
                  <Fragment set:html={step.icon} />
                </div>
              </div>
              <h3 class="mt-4 font-serif text-3xl text-slate-900">{step.title}</h3>
              <p class="mt-3 text-lg leading-relaxed text-slate-600">{step.description}</p>
            </div>

            {/* Visual side */}
            <div class="flex-1">
              <div class="aspect-[4/3] rounded-2xl border border-slate-200 bg-gradient-to-br from-slate-50 to-brand-50/30 p-8">
                <div class="flex h-full items-center justify-center text-brand-300">
                  <Fragment set:html={step.icon.replace('h-8 w-8', 'h-20 w-20')} />
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

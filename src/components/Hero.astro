---
---

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28 lg:pt-48 lg:pb-36">
  <!-- Background gradient -->
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand-50/60 via-coral-50/30 to-white"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute top-0 right-0 -z-10 h-[600px] w-[600px] rounded-full bg-gradient-to-br from-brand-200/20 to-coral-200/20 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="section-container relative">
    <div class="mx-auto max-w-4xl text-center">
      <!-- Badge -->
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand-700" style="animation: fadeInUp 0.6s ease-out both; animation-delay: 0ms;">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
        Now available on Atlassian Marketplace
      </div>

      <!-- Headline -->
      <h1
        class="font-serif text-5xl leading-[1.1] tracking-tight text-slate-900 sm:text-6xl lg:text-7xl"
        style="animation: fadeInUp 0.6s ease-out both; animation-delay: 100ms;"
      >
        Ship better stories.<br />
        <span class="gradient-text italic">Every sprint.</span>
      </h1>

      <!-- Subtitle -->
      <p
        class="mx-auto mt-8 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl"
        style="animation: fadeInUp 0.6s ease-out both; animation-delay: 200ms;"
      >
        Proompt reviews your Jira Epics and User Stories against your team's quality
        standards — before they hit a developer's screen. Catch vague requirements, missing
        acceptance criteria, and scope gaps in seconds.
      </p>

      <!-- CTAs -->
      <div
        class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
        style="animation: fadeInUp 0.6s ease-out both; animation-delay: 300ms;"
      >
        <a href="#pricing" class="btn-primary text-lg">
          Start Free
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href="#how-it-works" class="btn-secondary text-lg">See How It Works</a>
      </div>

      <!-- No credit card note -->
      <p
        class="mt-5 text-sm text-slate-400"
        style="animation: fadeInUp 0.6s ease-out both; animation-delay: 400ms;"
      >
        Free plan — no credit card required
      </p>
    </div>

    <!-- Product Mockup / Scorecard Preview -->
    <div
      class="mx-auto mt-16 max-w-3xl sm:mt-20"
      style="animation: fadeInUp 0.8s ease-out both; animation-delay: 500ms;"
    >
      <div class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-2xl shadow-slate-200/50">
        <!-- Mock browser chrome -->
        <div class="flex items-center gap-2 border-b border-slate-100 bg-slate-50 px-4 py-3">
          <div class="h-3 w-3 rounded-full bg-slate-200"></div>
          <div class="h-3 w-3 rounded-full bg-slate-200"></div>
          <div class="h-3 w-3 rounded-full bg-slate-200"></div>
          <div class="ml-4 h-6 flex-1 rounded-md bg-slate-100"></div>
        </div>

        <!-- Scorecard content -->
        <div class="p-6 sm:p-8">
          <div class="flex items-start justify-between">
            <div>
              <div class="flex items-center gap-2 text-sm text-slate-500">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                PROJ-1234 · Story
              </div>
              <h3 class="mt-1 text-lg font-semibold text-slate-900">
                User can reset password via email link
              </h3>
            </div>
            <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-400 to-emerald-500 text-2xl font-bold text-white shadow-lg shadow-emerald-200">
              A
            </div>
          </div>

          <!-- Score bars -->
          <div class="mt-6 space-y-3">
            {[
              { label: 'Clarity', score: 95, color: 'bg-emerald-500' },
              { label: 'Acceptance Criteria', score: 88, color: 'bg-emerald-500' },
              { label: 'Technical Design', score: 72, color: 'bg-amber-500' },
              { label: 'Scope Definition', score: 91, color: 'bg-emerald-500' },
            ].map((item) => (
              <div class="flex items-center gap-3">
                <span class="w-40 text-sm font-medium text-slate-600">{item.label}</span>
                <div class="h-2 flex-1 overflow-hidden rounded-full bg-slate-100">
                  <div
                    class={`h-full rounded-full ${item.color}`}
                    style={`width: ${item.score}%`}
                  />
                </div>
                <span class="w-8 text-right text-sm font-semibold text-slate-700">{item.score}</span>
              </div>
            ))}
          </div>

          <!-- Finding preview -->
          <div class="mt-5 rounded-lg border border-amber-200 bg-amber-50 p-3">
            <div class="flex items-start gap-2">
              <span class="mt-0.5 text-amber-500">
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
              </span>
              <div>
                <p class="text-sm font-medium text-amber-800">Technical Design — Missing error handling</p>
                <p class="mt-0.5 text-sm text-amber-700">Story doesn't specify behavior when the email link expires or is invalid.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

---
const stats = [
  { value: '10–15s', label: 'Average review time' },
  { value: '3–5 hrs', label: 'Saved per sprint' },
  { value: 'A–F', label: 'Letter grade scoring' },
  { value: '50+', label: 'Scoring dimensions' },
];
---

<section class="fade-in-section border-y border-slate-100 bg-slate-50/50 py-12 sm:py-16">
  <div class="section-container">
    <div class="grid grid-cols-2 gap-8 sm:gap-12 lg:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="text-center">
            <div class="font-serif text-3xl text-slate-900 sm:text-4xl">{stat.value}</div>
            <div class="mt-1 text-sm font-medium text-slate-500">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

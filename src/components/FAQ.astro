---
import { faqs } from '../data/faq';
---

<section id="faq" class="bg-slate-50/50 py-24 sm:py-32">
  <div class="section-container">
    <!-- Section heading -->
    <div class="fade-in-section mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">FAQ</p>
      <h2 class="mt-3 font-serif text-4xl text-slate-900 sm:text-5xl">
        Frequently asked <span class="italic text-brand-600">questions</span>
      </h2>
    </div>

    <!-- Accordion -->
    <div class="mx-auto mt-16 max-w-3xl divide-y divide-slate-200">
      {
        faqs.map((faq) => (
          <details class="fade-in-section group">
            <summary class="flex cursor-pointer items-center justify-between py-6">
              <h3 class="pr-8 text-lg font-medium text-slate-900 group-open:text-brand-600 transition-colors">
                {faq.question}
              </h3>
              <span class="faq-icon flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-slate-200 text-slate-400 transition-all duration-300 group-open:border-brand-300 group-open:bg-brand-50 group-open:text-brand-600">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
              </span>
            </summary>
            <div class="faq-content pb-6">
              <p class="leading-relaxed text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

---
const badges = [
  { name: 'SOC 2 Type II', label: 'SOC 2' },
  { name: 'ISO 27001', label: 'ISO' },
  { name: 'GDPR', label: 'GDPR' },
  { name: 'HIPAA', label: 'HIPAA' },
];

const securityFeatures = [
  {
    title: 'Zero data storage',
    description: 'Issue content is processed in memory and never stored by default.',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m6 4.125l2.25 2.25m0 0l2.25 2.25M12 13.875l2.25-2.25M12 13.875l-2.25 2.25M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>`,
  },
  {
    title: 'Encrypted in transit & at rest',
    description: 'TLS 1.2+ for all connections, AES-256 for stored data.',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
  },
  {
    title: 'Customer-managed keys',
    description: 'Bring your own encryption keys at the Enterprise tier.',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" /></svg>`,
  },
  {
    title: 'Data residency controls',
    description: 'Restrict processing to US or EU regions for compliance.',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
  },
  {
    title: 'Zero LLM data retention',
    description: 'Your stories are never used for model training by any provider.',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    title: 'Bring Your Own Key',
    description: 'Use your own LLM provider account for full data sovereignty.',
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0119.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 004.5 10.5a7.464 7.464 0 01-1.15 3.993m1.989 3.559A11.209 11.209 0 008.25 10.5a3.75 3.75 0 117.5 0c0 .527-.021 1.049-.064 1.565M12 10.5a14.94 14.94 0 01-3.6 9.75m6.633-4.596a18.666 18.666 0 01-2.485 5.33" /></svg>`,
  },
];
---

<section id="security" class="bg-slate-900 py-24 sm:py-32">
  <div class="section-container">
    <!-- Section heading -->
    <div class="fade-in-section mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-400">
        Security & Compliance
      </p>
      <h2 class="mt-3 font-serif text-4xl text-white sm:text-5xl">
        Enterprise-grade <span class="italic text-brand-300">security</span>
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        Built for regulated industries. Your data stays yours.
      </p>
    </div>

    <!-- Compliance badges -->
    <div class="fade-in-section mt-12 flex flex-wrap items-center justify-center gap-6">
      {
        badges.map((badge) => (
          <div class="flex h-20 w-20 flex-col items-center justify-center rounded-2xl border border-slate-700 bg-slate-800 sm:h-24 sm:w-24">
            <span class="text-lg font-bold text-white sm:text-xl">{badge.label}</span>
            <span class="mt-0.5 text-[10px] text-slate-400">{badge.name === badge.label ? 'Compliant' : ''}</span>
          </div>
        ))
      }
    </div>

    <!-- Security features grid -->
    <div class="mx-auto mt-16 grid max-w-4xl gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        securityFeatures.map((feature) => (
          <div class="fade-in-section rounded-xl border border-slate-700/50 bg-slate-800/50 p-6">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-500/10 text-brand-400">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="mt-3 font-semibold text-white">{feature.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-slate-400">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

---
import { features } from '../data/features';
---

<section id="features" class="bg-slate-50/50 py-24 sm:py-32">
  <div class="section-container">
    <!-- Section heading -->
    <div class="fade-in-section mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">Features</p>
      <h2 class="mt-3 font-serif text-4xl text-slate-900 sm:text-5xl">
        Everything you need to ship<br class="hidden sm:block" />
        <span class="italic text-brand-600">quality stories</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        A complete review system that catches what humans miss — and fixes it for you.
      </p>
    </div>

    <!-- Feature Grid -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <div
            class={`fade-in-section group rounded-2xl border bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg ${
              feature.highlighted
                ? 'border-brand-200 shadow-md shadow-brand-100/50'
                : 'border-slate-200 hover:border-brand-200'
            }`}
          >
            <div
              class={`flex h-12 w-12 items-center justify-center rounded-xl text-2xl ${
                feature.highlighted ? 'bg-brand-50' : 'bg-slate-50 group-hover:bg-brand-50'
              } transition-colors`}
            >
              {feature.icon}
            </div>
            <h3 class="mt-5 text-lg font-semibold text-slate-900">{feature.title}</h3>
            <p class="mt-2 leading-relaxed text-slate-600">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

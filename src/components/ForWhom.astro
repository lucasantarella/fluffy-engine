---
const personas = [
  {
    role: 'Product Managers',
    description:
      'Stop being the quality bottleneck. AI PM catches missing acceptance criteria, vague descriptions, and undefined scope — before the ticket reaches a developer.',
    gradient: 'from-brand-500 to-brand-600',
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
  },
  {
    role: 'Engineering Leads',
    description:
      'Eliminate "this story isn\'t ready" as a standup topic. Every story that enters a sprint has been reviewed against the team\'s standards.',
    gradient: 'from-blue-500 to-indigo-600',
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>`,
  },
  {
    role: 'QA Engineers',
    description:
      'Start every ticket with testable acceptance criteria. AI PM flags stories that don\'t have them — and drafts criteria when they\'re missing.',
    gradient: 'from-emerald-500 to-teal-600',
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
  {
    role: 'Agile Coaches',
    description:
      'Measure and improve story quality across teams. Track which dimensions improve, benchmark teams, and use data to drive process improvement.',
    gradient: 'from-amber-500 to-orange-600',
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5" /></svg>`,
  },
  {
    role: 'Regulated Industries',
    description:
      'Built for teams that can\'t cut corners on documentation. HIPAA BAA, SOC 2, ISO 27001, GDPR. Customer-managed encryption keys and data residency controls.',
    gradient: 'from-rose-500 to-pink-600',
    icon: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  },
];
---

<section class="py-24 sm:py-32">
  <div class="section-container">
    <!-- Section heading -->
    <div class="fade-in-section mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand-600">Who it's for</p>
      <h2 class="mt-3 font-serif text-4xl text-slate-900 sm:text-5xl">
        Built for the whole<br class="hidden sm:block" />
        <span class="italic text-brand-600">product team</span>
      </h2>
    </div>

    <!-- Persona cards -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        personas.map((persona) => (
          <div class="fade-in-section group relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
            {/* Gradient left accent */}
            <div
              class={`absolute top-0 left-0 h-full w-1 bg-gradient-to-b ${persona.gradient}`}
            />

            <div
              class={`flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br ${persona.gradient} text-white`}
            >
              <Fragment set:html={persona.icon} />
            </div>

            <h3 class="mt-4 text-lg font-semibold text-slate-900">{persona.role}</h3>
            <p class="mt-2 leading-relaxed text-slate-600">{persona.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
